# WordPress REST API
ADANAAVUKAT_WP_BASE_URL=https://adanaavukat.org
ADANAAVUKAT_WP_USERNAME=your-wordpress-username
ADANAAVUKAT_WP_APP_PASSWORD=your-application-password

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLE_SEARCH_GROUNDING=true

# Stock image APIs (en az biri gerekli)
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=

# Alternatif WP env isimleri (opsiyonel)
# WP_BASE_URL=https://adanaavukat.org
# WP_USERNAME=
# WP_APP_PASSWORD=
GEMINI_GOOGLE_SEARCH_ENABLED=true
